source "https://rubygems.org"

# Dieses Gem sorgt dafür, dass du lokal exakt die Jekyll-Version
# nutzt, die GitHub Pages auch beim Hosting verwendet.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
end

# Windows-Kompatibilität
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]
gem "webrick"
